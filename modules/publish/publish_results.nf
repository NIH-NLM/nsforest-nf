/**
 * Publish Results to cell-kn GitHub Repository
 *
 * Fires once per dataset after all processes complete.
 * Files are staged by Nextflow into the work directory.
 *
 * Branch naming:
 *   {YYYY}-{mon}-{DD}-{organ}-{first_author}-{year}-sc-nsforest-qc-nf
 *   e.g. 2026-mar-06-skin-of-body-Wiedemann-2023-sc-nsforest-qc-nf
 *
 * Required params:
 *   params.github_token   GitHub PAT with repo write access.
 *   params.outdir         Results directory written by all publishDir steps.
 */
process publish_results_process {
    tag "publish_${meta.organ}_${meta.first_author}_${meta.year}"
    label 'publish'

    publishDir "${params.outdir}",
        mode: params.publish_mode,
        pattern: "publish_report_*.txt"

    input:
    tuple val(meta), path(all_files)

    output:
    path "publish_report_${meta.organ}_${meta.first_author}_${meta.year}.txt", emit: report

    script:
    def today     = new java.text.SimpleDateFormat("yyyy-MMM-dd").format(new Date()).toLowerCase()
    def organSlug = meta.organ.replace('_', '-')
    def branch    = "${today}-${organSlug}-${meta.first_author}-${meta.year}-sc-nsforest-qc-nf"
    def label     = "outputs_${meta.organ}_${meta.first_author}_${meta.year}"
    def repo_url  = "https://\${GITHUB_TOKEN}@github.com/NIH-NLM/cell-kn.git"
    def report    = "publish_report_${meta.organ}_${meta.first_author}_${meta.year}.txt"
    """
    set -euo pipefail

    export GITHUB_TOKEN="${params.github_token}"

    echo "=========================================="
    echo " organ  : ${meta.organ}"
    echo " author : ${meta.first_author}"
    echo " year   : ${meta.year}"
    echo " branch : ${branch}"
    echo "=========================================="

    git clone --depth 1 ${repo_url} cell-kn
    cd cell-kn
    git config user.email "nextflow-publish@nih.gov"
    git config user.name  "Nextflow Publish Bot"
    git checkout -b ${branch}

    dest="data/prod/${meta.organ}/sc-nsforest-qc/${label}"
    mkdir -p "\$dest"

    n=0
    for filepath in ${all_files}; do
        [ -f "\$filepath" ] || continue
        case "\$filepath" in *.h5ad|*.pkl) continue;; esac
        cp -p "\$filepath" "\$dest/"
        n=\$(( n + 1 ))
    done

    echo "Files copied: \$n"

    git add data/prod/${meta.organ}/sc-nsforest-qc/

    if git diff --cached --quiet; then
        echo "WARNING: nothing new to commit"
        cat > ../${report} << REPORT
organ:      ${meta.organ}
author:     ${meta.first_author}
year:       ${meta.year}
branch:     ${branch}
files:      \${n}
status:     nothing to commit — already up to date
branch_url: (push skipped)
REPORT
        exit 0
    fi

    git commit -m "workflow: publish ${meta.organ} ${meta.first_author} ${meta.year} results (${today})

Organ  : ${meta.organ}
Author : ${meta.first_author}
Year   : ${meta.year}
Run    : ${workflow.runName}
Files  : \${n}

Auto-generated by sc-nsforest-qc-nf."

    git push origin ${branch}

    cat > ../${report} << REPORT
organ:      ${meta.organ}
author:     ${meta.first_author}
year:       ${meta.year}
branch:     ${branch}
files:      \${n}
status:     branch pushed — open PR manually after review
branch_url: https://github.com/NIH-NLM/cell-kn/tree/${branch}
REPORT
    cat ../${report}
    """
}
