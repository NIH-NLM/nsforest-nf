/*
 * chapter09.config
 * ================
 * Elements of Style — Chapter 9 configuration.
 *
 * Publishes workflow artifacts directly into the book's docs folder
 * so results appear at docs/chapter-09/results/ in the
 * elements-of-style-workflows repository.
 *
 * Both repos must be cloned as siblings in the same parent directory:
 *   projects/
 *     sc-nsforest-qc-nf/          ← run from here
 *     elements-of-style-workflows/
 *       docs/chapter-09/results/  ← artifacts land here
 *
 * Usage (local):
 *   nextflow run main.nf \
 *     -c configs/macamd64.config \
 *     -c configs/chapter09.config
 *
 * Usage (CloudOS):
 *   Use this config as-is; override outdir in the CloudOS launch UI
 *   to your S3 output path, then copy results into the book repo.
 */

params {
    outdir       = "${projectDir}/../../elements-of-style-workflows/docs/chapter-09/results"
    datasets_csv = "${projectDir}/data/endometriosis_Tan_2022.csv"
    organ        = 'endometrium'
    uberon_json  = "${projectDir}/data/uberon_endometrium.json"
    disease_json = "${projectDir}/data/disease_endometriosis.json"
    hsapdv_json  = "${projectDir}/data/hsapdv_reproductive_age.json"
}
